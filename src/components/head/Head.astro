---
import PreloadFonts from './PreloadFonts.astro';
import Icons from '@components/head/Icons.astro';
import OpenGraph from '@components/head/OpenGraph.astro';
import { site } from '@data/config.js';

import '@styles/global.scss';

const preloadFonts = [''];

const { title, description = title } = Astro.props;
---

<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <PreloadFonts fonts={preloadFonts} />

  <Icons />

  <!-- Metadata -->
  <meta name="generator" content={Astro.generator} />
  <title>{`${title} | ${site.title}`}</title>
  <meta name="description" content={description} />

  <OpenGraph title={title} description={description} />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>

---
import Base from "@layouts/Base.astro";
import Email from "@components/Email.astro";
import { client } from "@data/config.mjs";
---

<Base title="Page Not Found">
  <h1>Page Not Found</h1>
  <p>
    It looks like this page doesn't exist. If you think this is a mistake please
    email us at <Email email={client.email}>{client.email}</Email>.
  </p>
</Base>
